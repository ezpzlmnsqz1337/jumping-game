{
  "name": "jumping-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test:ui": "vitest run",
    "test:ui:coverage": "vitest run --coverage",
    "test:ui:watch": "vitest",
    "build:server": "bash -c ./build-server.sh",
    "build:watch": "vite build --watch",
    "build:all": "bash -c ./build-all.sh",
    "start:server": "nvm use && cd multiplayer-server && npm run start",
    "deploy:homelab": "bash -c ./deploy.sh",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:css": "stylelint \"public/assets/ui/**/*.css\"",
    "lint:css:fix": "stylelint --fix \"public/assets/ui/**/*.css\"",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babylonjs/core": "^7.41.1",
    "@eslint/js": "^9.0.0",
    "@types/earcut": "^2.1.4",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@babylonjs/gui": "^7.42.0",
    "@babylonjs/havok": "^1.3.10",
    "@babylonjs/loaders": "^7.42.0",
    "colyseus.js": "^0.15.26",
    "earcut": "^3.0.1",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  }
}
